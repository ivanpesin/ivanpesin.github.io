      <p> Подсеть 2(10) </p>
    </td>
    <td width="84" valign="top" bgcolor="#a6a6a6"> 
      <p> 10010000 </p>
    </td>
    <td width="84" valign="top" bgcolor="#a6a6a6"> 
      <p> 10010000 </p>
