      </li>
      <li>
        rfc1003 (VLSM)
      </li>
      <li>
        rfc1517 (CIDR)
      </li>
      <li>
        rfc1518 (CIDR)
      </li>
      <li>
        rfc1519 (CIDR)
      </li>
      <li>
        rfc1520 (CIDR)
      </li>
    </ol>
 
